# Servicio oficial de cómputo (backend PostgreSQL) cuando esté disponible.
VITE_OFICIAL_API_URL=http://localhost:4000

# Servicio RRV / MongoDB cuando el equipo lo exponga.
# Si no existe, el dashboard usa src/data/rrv.mock.js.
VITE_RRV_API_URL=http://localhost:4001

# Por defecto el formulario NO envía automáticamente al backend.
# El integrador puede activarlo cuando el endpoint final esté listo.
VITE_ENABLE_API_SUBMIT=false
