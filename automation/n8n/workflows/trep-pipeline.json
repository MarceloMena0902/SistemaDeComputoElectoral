{
  "name": "TREP - Pipeline RRV de Actas Electorales",
  "nodes": [
    {
      "id": "webhook-recepcion",
      "name": "Webhook - Recepción App Móvil",
      "type": "n8n-nodes-base.webhook",
      "position": [100, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "acta-rrv",
        "responseMode": "responseNode",
        "options": {
          "rawBody": false
        }
      }
    },
    {
      "id": "validar-payload",
      "name": "Validar Payload",
      "type": "n8n-nodes-base.code",
      "position": [320, 300],
      "parameters": {
        "jsCode": "// Validar que el payload tiene los campos requeridos\nconst { mesa_id, pipeline, usuario_id } = $input.first().json.body;\n\nconst errores = [];\nif (!mesa_id) errores.push('mesa_id es requerido');\nif (!pipeline) errores.push('pipeline es requerido');\nif (!['RRV', 'COMPUTO_OFICIAL'].includes(pipeline)) errores.push('pipeline inválido');\n\nif (errores.length > 0) {\n  throw new Error('Payload inválido: ' + errores.join(', '));\n}\n\nreturn $input.all();"
      }
    },
    {
      "id": "enviar-vision-ai",
      "name": "Enviar a Vision-AI (OCR)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [540, 300],
      "parameters": {
        "method": "POST",
        "url": "http://vision-ai:8000/actas/procesar",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            { "name": "imagen", "value": "={{ $json.body.imagen }}", "parameterType": "formBinaryData" },
            { "name": "mesa_id", "value": "={{ $json.body.mesa_id }}" },
            { "name": "pipeline", "value": "={{ $json.body.pipeline }}" },
            { "name": "usuario_id", "value": "={{ $json.body.usuario_id }}" },
            { "name": "latitud", "value": "={{ $json.body.latitud }}" },
            { "name": "longitud", "value": "={{ $json.body.longitud }}" }
          ]
        },
        "options": {
          "timeout": 60000,
          "response": { "response": { "responseFormat": "json" } }
        }
      }
    },
    {
      "id": "evaluar-calidad",
      "name": "Evaluar Calidad OCR",
      "type": "n8n-nodes-base.switch",
      "position": [760, 300],
      "parameters": {
        "dataType": "number",
        "value1": "={{ $json.calidad_imagen }}",
        "rules": {
          "rules": [
            { "operation": "largerEqual", "value2": 70, "output": 0 },
            { "operation": "smaller", "value2": 70, "output": 1 }
          ]
        }
      }
    },
    {
      "id": "actualizar-estado-validada",
      "name": "Marcar Acta VALIDADA",
      "type": "n8n-nodes-base.postgres",
      "position": [980, 200],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE actas SET estado = 'VALIDADA', validada_en = NOW() WHERE uuid = '{{ $json.acta_uuid }}'",
        "options": {}
      }
    },
    {
      "id": "actualizar-estado-observada",
      "name": "Marcar Acta OBSERVADA",
      "type": "n8n-nodes-base.postgres",
      "position": [980, 400],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE actas SET estado = 'OBSERVADA', observaciones = 'Calidad OCR insuficiente ({{ $json.calidad_imagen }}%)' WHERE uuid = '{{ $json.acta_uuid }}'",
        "options": {}
      }
    },
    {
      "id": "notificar-supervisor",
      "name": "Notificar Supervisor (Observada)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1200, 400],
      "parameters": {
        "method": "POST",
        "url": "http://vision-ai:8000/notificaciones/supervisor",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "acta_uuid", "value": "={{ $json.acta_uuid }}" },
            { "name": "mesa_id", "value": "={{ $json.mesa_id }}" },
            { "name": "motivo", "value": "Calidad OCR insuficiente" }
          ]
        }
      }
    },
    {
      "id": "respuesta-exitosa",
      "name": "Respuesta Exitosa",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1200, 200],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"status\": \"ok\", \"acta_uuid\": $json.acta_uuid, \"calidad\": $json.calidad_imagen, \"mensaje\": \"Acta procesada y validada correctamente\" } }}",
        "options": { "responseCode": 200 }
      }
    },
    {
      "id": "respuesta-observada",
      "name": "Respuesta Observada",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1420, 400],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"status\": \"observada\", \"acta_uuid\": $json.acta_uuid, \"calidad\": $json.calidad_imagen, \"mensaje\": \"Acta marcada como observada, se notificó al supervisor\" } }}",
        "options": { "responseCode": 202 }
      }
    },
    {
      "id": "manejo-errores",
      "name": "Manejo de Errores",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [540, 500],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"status\": \"error\", \"mensaje\": \"{{ $json.message }}\" }",
        "options": { "responseCode": 400 }
      }
    }
  ],
  "connections": {
    "Webhook - Recepción App Móvil": {
      "main": [[{ "node": "Validar Payload", "type": "main", "index": 0 }]]
    },
    "Validar Payload": {
      "main": [[{ "node": "Enviar a Vision-AI (OCR)", "type": "main", "index": 0 }]],
      "error": [[{ "node": "Manejo de Errores", "type": "main", "index": 0 }]]
    },
    "Enviar a Vision-AI (OCR)": {
      "main": [[{ "node": "Evaluar Calidad OCR", "type": "main", "index": 0 }]]
    },
    "Evaluar Calidad OCR": {
      "main": [
        [{ "node": "Marcar Acta VALIDADA", "type": "main", "index": 0 }],
        [{ "node": "Marcar Acta OBSERVADA", "type": "main", "index": 0 }]
      ]
    },
    "Marcar Acta VALIDADA": {
      "main": [[{ "node": "Respuesta Exitosa", "type": "main", "index": 0 }]]
    },
    "Marcar Acta OBSERVADA": {
      "main": [[{ "node": "Notificar Supervisor (Observada)", "type": "main", "index": 0 }]]
    },
    "Notificar Supervisor (Observada)": {
      "main": [[{ "node": "Respuesta Observada", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "errorWorkflow": "manejo-errores"
  },
  "staticData": null,
  "tags": ["electoral", "rrv", "trep"]
}
